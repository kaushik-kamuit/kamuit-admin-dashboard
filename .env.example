# ---------- DB credentials (local containers) ----------
# Do NOT put real Render credentials here. This project is local-only.

LOCAL_PG_USER=kamuit_admin
LOCAL_PG_PASSWORD=local_dev_only

# User management DB
USER_MGMT_DB_HOST=localhost
USER_MGMT_DB_PORT=54321
USER_MGMT_DB_NAME=kamuit_user_management

# Kamuit backend DB (rides, driver_runs, preferences — PostGIS)
KAMUIT_DB_HOST=localhost
KAMUIT_DB_PORT=54322
KAMUIT_DB_NAME=kamuit_backend

# Payment backend DB
PAYMENT_DB_HOST=localhost
PAYMENT_DB_PORT=54323
PAYMENT_DB_NAME=kamuit_payment

# ---------- Admin API ----------
ADMIN_API_HOST=127.0.0.1
ADMIN_API_PORT=8000

# Single shared admin login. Local-only. Not secure; do not reuse.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# JWT signing (rotate if you care)
ADMIN_JWT_SECRET=change-me-for-local-dev-only-not-production
ADMIN_JWT_ALGORITHM=HS256
ADMIN_JWT_EXPIRE_MINUTES=480

# ---------- Admin Web ----------
VITE_API_BASE_URL=http://127.0.0.1:8000
